    {
      "name": "3. Get Violations & Assert Severity",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Violations array contains logged anomalies\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "    \r",
              "    var hasCritical = jsonData.some(v => v.severity === 'CRITICAL');\r",
              "    pm.expect(hasCritical).to.be.true;\r",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/telemetry/violations",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "telemetry", "violations"]
        }
      }
    }
